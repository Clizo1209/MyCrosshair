<Window x:Class="MyCrosshair.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MyCrosshair"
        Title="MyCrosshair" Width="420" Height="620"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,5"/>
        </Style>

        <Style x:Key="FlatBtn" TargetType="Button">
            <Setter Property="Background" Value="#27AE60"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2ECC71"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1E8449"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="0,8,0,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#C0392B"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#1C1C1C" CornerRadius="10" BorderBrush="#3A3A3A" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" MouseDown="TitleBar_MouseDown" Cursor="SizeAll" Background="Transparent">
                <Border Background="#141414" CornerRadius="10,10,0,0"/>
                <TextBlock Text="MyCrosshair  配置" Foreground="#EEEEEE"
                           FontSize="13" FontWeight="Medium"
                           Margin="14,0" VerticalAlignment="Center"/>
                <Button Style="{StaticResource CloseBtn}" Content="✕"
                        HorizontalAlignment="Right" Click="CloseBtn_Click"/>
            </Grid>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          Padding="0,0,2,0">
                <StackPanel Margin="16,12,16,16">

                    <!-- Preview -->
                    <Border Background="#0D0D0D" Height="140" CornerRadius="6"
                            Margin="0,0,0,14" BorderBrush="#333" BorderThickness="1"
                            ClipToBounds="True">
                        <local:CrosshairRenderer/>
                    </Border>

                    <!-- 颜色 -->
                    <TextBlock Text="颜色" Foreground="#666" FontSize="11"
                               FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <Border Background="#242424" CornerRadius="6" Padding="12,10" Margin="0,0,0,12">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="当前颜色"/>
                                <Border Grid.Column="1" x:Name="ColorPreview" Height="22"
                                        CornerRadius="4" BorderBrush="#555" BorderThickness="1"
                                        Background="#00FF64"/>
                            </Grid>
                            <!-- R -->
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="红 R" Foreground="#FF6B6B"/>
                                <Slider Grid.Column="1" x:Name="SliderR" Minimum="0" Maximum="255"
                                        IsSnapToTickEnabled="True" TickFrequency="1"
                                        ValueChanged="Color_ValueChanged" Margin="8,0"/>
                                <TextBlock Grid.Column="2" x:Name="ValR" TextAlignment="Right"/>
                            </Grid>
                            <!-- G -->
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="绿 G" Foreground="#6BCB77"/>
                                <Slider Grid.Column="1" x:Name="SliderG" Minimum="0" Maximum="255"
                                        IsSnapToTickEnabled="True" TickFrequency="1"
                                        ValueChanged="Color_ValueChanged" Margin="8,0"/>
                                <TextBlock Grid.Column="2" x:Name="ValG" TextAlignment="Right"/>
                            </Grid>
                            <!-- B -->
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="蓝 B" Foreground="#6BB5FF"/>
                                <Slider Grid.Column="1" x:Name="SliderB" Minimum="0" Maximum="255"
                                        IsSnapToTickEnabled="True" TickFrequency="1"
                                        ValueChanged="Color_ValueChanged" Margin="8,0"/>
                                <TextBlock Grid.Column="2" x:Name="ValB" TextAlignment="Right"/>
                            </Grid>
                            <!-- Opacity -->
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="透明度"/>
                                <Slider Grid.Column="1" x:Name="SliderOpacity" Minimum="10" Maximum="100"
                                        IsSnapToTickEnabled="True" TickFrequency="1"
                                        ValueChanged="Shape_ValueChanged" Margin="8,0"/>
                                <TextBlock Grid.Column="2" x:Name="ValOpacity" TextAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- 形状 -->
                    <TextBlock Text="形状" Foreground="#666" FontSize="11"
                               FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <Border Background="#242424" CornerRadius="6" Padding="12,10" Margin="0,0,0,12">
                        <StackPanel>
                            <!-- Length -->
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="长度"/>
                                <Slider Grid.Column="1" x:Name="SliderLength" Minimum="1" Maximum="60"
                                        IsSnapToTickEnabled="True" TickFrequency="1"
                                        ValueChanged="Shape_ValueChanged" Margin="8,0"/>
                                <TextBlock Grid.Column="2" x:Name="ValLength" TextAlignment="Right"/>
                            </Grid>
                            <!-- Thickness -->
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="粗细"/>
                                <Slider Grid.Column="1" x:Name="SliderThickness" Minimum="1" Maximum="10"
                                        IsSnapToTickEnabled="True" TickFrequency="1"
                                        ValueChanged="Shape_ValueChanged" Margin="8,0"/>
                                <TextBlock Grid.Column="2" x:Name="ValThickness" TextAlignment="Right"/>
                            </Grid>
                            <!-- Gap -->
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="间隙"/>
                                <Slider Grid.Column="1" x:Name="SliderGap" Minimum="0" Maximum="30"
                                        IsSnapToTickEnabled="True" TickFrequency="1"
                                        ValueChanged="Shape_ValueChanged" Margin="8,0"/>
                                <TextBlock Grid.Column="2" x:Name="ValGap" TextAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- 选项 -->
                    <TextBlock Text="选项" Foreground="#666" FontSize="11"
                               FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <Border Background="#242424" CornerRadius="6" Padding="12,10" Margin="0,0,0,16">
                        <StackPanel>
                            <CheckBox x:Name="ChkOutline" Content="显示轮廓"
                                      Checked="Option_Changed" Unchecked="Option_Changed"/>
                            <!-- Outline thickness -->
                            <Grid Margin="0,3" x:Name="OutlineThicknessRow">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="轮廓粗细" Foreground="#999"/>
                                <Slider Grid.Column="1" x:Name="SliderOutline" Minimum="1" Maximum="5"
                                        IsSnapToTickEnabled="True" TickFrequency="1"
                                        ValueChanged="Shape_ValueChanged" Margin="8,0"/>
                                <TextBlock Grid.Column="2" x:Name="ValOutline" TextAlignment="Right"/>
                            </Grid>
                            <CheckBox x:Name="ChkDot" Content="显示中心点" Margin="0,8,0,0"
                                      Checked="Option_Changed" Unchecked="Option_Changed"/>
                            <Grid Margin="0,3" x:Name="DotSizeRow">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="点大小" Foreground="#999"/>
                                <Slider Grid.Column="1" x:Name="SliderDotSize" Minimum="1" Maximum="20"
                                        IsSnapToTickEnabled="True" TickFrequency="1"
                                        ValueChanged="Shape_ValueChanged" Margin="8,0"/>
                                <TextBlock Grid.Column="2" x:Name="ValDotSize" TextAlignment="Right"/>
                            </Grid>
                            <CheckBox x:Name="ChkTShape" Content="T 形准星（无上臂）"
                                      Checked="Option_Changed" Unchecked="Option_Changed"/>
                        </StackPanel>
                    </Border>

                    <!-- Save -->
                    <Button x:Name="SaveBtn" Style="{StaticResource FlatBtn}"
                            Content="保存配置" Width="160" Height="36"
                            HorizontalAlignment="Center" Padding="0"
                            Click="SaveBtn_Click"/>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
