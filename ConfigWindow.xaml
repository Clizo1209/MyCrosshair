<Window x:Class="MyCrosshair.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MyCrosshair"
        Title="MyCrosshair" Width="480" Height="660"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,5"/>
        </Style>

        <!-- 数值输入框 -->
        <Style x:Key="ValBox" TargetType="TextBox">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#EEEEEE"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="3,2"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="CaretBrush" Value="#EEEEEE"/>
            <Setter Property="SelectionBrush" Value="#27AE60"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="FlatBtn" TargetType="Button">
            <Setter Property="Background" Value="#27AE60"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2ECC71"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1E8449"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="0,8,0,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#C0392B"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#1C1C1C" CornerRadius="10" BorderBrush="#3A3A3A" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" MouseDown="TitleBar_MouseDown" Cursor="SizeAll" Background="Transparent">
                <Border Background="#141414" CornerRadius="10,10,0,0"/>
                <TextBlock x:Name="TitleText" Foreground="#EEEEEE"
                           FontSize="13" FontWeight="Medium"
                           Margin="14,0" VerticalAlignment="Center"/>
                <Button Style="{StaticResource CloseBtn}" Content="✕"
                        HorizontalAlignment="Right" Click="CloseBtn_Click"/>
            </Grid>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,2,0">
                <StackPanel Margin="16,12,16,16">

                    <!-- Preview -->
                    <Border Background="#0D0D0D" Height="140" CornerRadius="6"
                            Margin="0,0,0,14" BorderBrush="#333" BorderThickness="1"
                            ClipToBounds="True">
                        <local:CrosshairRenderer/>
                    </Border>

                    <!-- 颜色 -->
                    <TextBlock x:Name="SecColor" Foreground="#666" FontSize="11"
                               FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <Border Background="#242424" CornerRadius="6" Padding="12,10" Margin="0,0,0,12">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="LblCurrentColor"/>
                                <Border Grid.Column="1" x:Name="ColorPreview" Height="22"
                                        CornerRadius="4" BorderBrush="#555" BorderThickness="1"
                                        Background="#00FF64"/>
                            </Grid>
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="46"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="LblR" Foreground="#FF6B6B"/>
                                <Slider Grid.Column="1" x:Name="SliderR" Minimum="0" Maximum="255"
                                        IsSnapToTickEnabled="True" TickFrequency="1"
                                        ValueChanged="Color_ValueChanged" Margin="8,0"/>
                                <TextBox Grid.Column="2" x:Name="ValR" Style="{StaticResource ValBox}"
                                         TextChanged="ValBox_TextChanged"/>
                            </Grid>
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="46"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="LblG" Foreground="#6BCB77"/>
                                <Slider Grid.Column="1" x:Name="SliderG" Minimum="0" Maximum="255"
                                        IsSnapToTickEnabled="True" TickFrequency="1"
                                        ValueChanged="Color_ValueChanged" Margin="8,0"/>
                                <TextBox Grid.Column="2" x:Name="ValG" Style="{StaticResource ValBox}"
                                         TextChanged="ValBox_TextChanged"/>
                            </Grid>
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="46"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="LblB" Foreground="#6BB5FF"/>
                                <Slider Grid.Column="1" x:Name="SliderB" Minimum="0" Maximum="255"
                                        IsSnapToTickEnabled="True" TickFrequency="1"
                                        ValueChanged="Color_ValueChanged" Margin="8,0"/>
                                <TextBox Grid.Column="2" x:Name="ValB" Style="{StaticResource ValBox}"
                                         TextChanged="ValBox_TextChanged"/>
                            </Grid>
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="46"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="LblOpacity"/>
                                <Slider Grid.Column="1" x:Name="SliderOpacity" Minimum="10" Maximum="100"
                                        IsSnapToTickEnabled="True" TickFrequency="1"
                                        ValueChanged="Shape_ValueChanged" Margin="8,0"/>
                                <TextBox Grid.Column="2" x:Name="ValOpacity" Style="{StaticResource ValBox}"
                                         TextChanged="ValBox_TextChanged"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- 形状 -->
                    <TextBlock x:Name="SecShape" Foreground="#666" FontSize="11"
                               FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <Border Background="#242424" CornerRadius="6" Padding="12,10" Margin="0,0,0,12">
                        <StackPanel>
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="46"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="LblLength"/>
                                <Slider Grid.Column="1" x:Name="SliderLength" Minimum="1" Maximum="60"
                                        IsSnapToTickEnabled="True" TickFrequency="1"
                                        ValueChanged="Shape_ValueChanged" Margin="8,0"/>
                                <TextBox Grid.Column="2" x:Name="ValLength" Style="{StaticResource ValBox}"
                                         TextChanged="ValBox_TextChanged"/>
                            </Grid>
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="46"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="LblThickness"/>
                                <Slider Grid.Column="1" x:Name="SliderThickness" Minimum="1" Maximum="10"
                                        IsSnapToTickEnabled="True" TickFrequency="1"
                                        ValueChanged="Shape_ValueChanged" Margin="8,0"/>
                                <TextBox Grid.Column="2" x:Name="ValThickness" Style="{StaticResource ValBox}"
                                         TextChanged="ValBox_TextChanged"/>
                            </Grid>
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="46"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="LblGap"/>
                                <Slider Grid.Column="1" x:Name="SliderGap" Minimum="0" Maximum="30"
                                        IsSnapToTickEnabled="True" TickFrequency="1"
                                        ValueChanged="Shape_ValueChanged" Margin="8,0"/>
                                <TextBox Grid.Column="2" x:Name="ValGap" Style="{StaticResource ValBox}"
                                         TextChanged="ValBox_TextChanged"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- 选项 -->
                    <TextBlock x:Name="SecOptions" Foreground="#666" FontSize="11"
                               FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <Border Background="#242424" CornerRadius="6" Padding="12,10" Margin="0,0,0,12">
                        <StackPanel>
                            <CheckBox x:Name="ChkOutline"
                                      Checked="Option_Changed" Unchecked="Option_Changed"/>
                            <Grid Margin="0,3" x:Name="OutlineThicknessRow">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="46"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="LblOutlineThick" Foreground="#999"/>
                                <Slider Grid.Column="1" x:Name="SliderOutline" Minimum="1" Maximum="5"
                                        IsSnapToTickEnabled="True" TickFrequency="1"
                                        ValueChanged="Shape_ValueChanged" Margin="8,0"/>
                                <TextBox Grid.Column="2" x:Name="ValOutline" Style="{StaticResource ValBox}"
                                         TextChanged="ValBox_TextChanged"/>
                            </Grid>
                            <CheckBox x:Name="ChkDot" Margin="0,8,0,0"
                                      Checked="Option_Changed" Unchecked="Option_Changed"/>
                            <Grid Margin="0,3" x:Name="DotSizeRow">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="46"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="LblDotSize" Foreground="#999"/>
                                <Slider Grid.Column="1" x:Name="SliderDotSize" Minimum="1" Maximum="20"
                                        IsSnapToTickEnabled="True" TickFrequency="1"
                                        ValueChanged="Shape_ValueChanged" Margin="8,0"/>
                                <TextBox Grid.Column="2" x:Name="ValDotSize" Style="{StaticResource ValBox}"
                                         TextChanged="ValBox_TextChanged"/>
                            </Grid>
                            <CheckBox x:Name="ChkTShape"
                                      Checked="Option_Changed" Unchecked="Option_Changed"/>
                        </StackPanel>
                    </Border>

                    <!-- 语言 -->
                    <Border Background="#242424" CornerRadius="6" Padding="12,10" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="LblLanguage" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" x:Name="LangCombo" Width="110"
                                      Background="#3A3A3A" Foreground="#CCCCCC" BorderBrush="#555"
                                      SelectionChanged="Lang_SelectionChanged">
                                <ComboBoxItem Content="中文" Tag="zh"/>
                                <ComboBoxItem Content="English" Tag="en"/>
                            </ComboBox>
                        </Grid>
                    </Border>

                    <!-- Save -->
                    <Button x:Name="SaveBtn" Style="{StaticResource FlatBtn}"
                            Width="160" Height="36"
                            HorizontalAlignment="Center" Padding="0"
                            Click="SaveBtn_Click"/>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
